{
  "name": "homebridge-google-nest-sdm-v2",
  "displayName": "Google Nest SDM (v2)",
  "version": "2.0.6",
  "description": "Homebridge plugin for Google Nest cameras, doorbells and thermostats via the Smart Device Management API. A maintained fork of homebridge-google-nest-sdm with refreshing camera snapshots, configurable ffmpeg/hardware transcoding, rate-limit hardening, and Homebridge v2 support.",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf ./dist",
    "copy-files": "copyfiles -u 1 src/res/*.* dist/",
    "build": "npm run clean && tsc && npm run copy-files",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "engines": {
    "homebridge": "^1.6.0 || ^2.0.0",
    "node": ">=22"
  },
  "keywords": [
    "homebridge",
    "homebridge-plugin",
    "nest",
    "google-nest",
    "doorbell",
    "camera",
    "thermostat",
    "smart-device-management",
    "sdm"
  ],
  "author": "Zac",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nnmb2vgw4r-sudo/homebridge-google-nest-sdm-v2.git"
  },
  "homepage": "https://github.com/nnmb2vgw4r-sudo/homebridge-google-nest-sdm-v2#readme",
  "bugs": {
    "url": "https://github.com/nnmb2vgw4r-sudo/homebridge-google-nest-sdm-v2/issues"
  },
  "license": "ISC",
  "files": [
    "dist",
    "config.schema.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@google-cloud/pubsub": "^4.11.0",
    "axios": "^1.16.0",
    "ffmpeg-for-homebridge": "2.2.2",
    "googleapis": "^87.0.0",
    "ip": "^1.1.5",
    "lodash": "^4.17.21",
    "pick-port": "^1.0.1",
    "systeminformation": "^5.31.6",
    "werift": "0.18.7"
  },
  "devDependencies": {
    "@types/ip": "^1.1.0",
    "@types/lodash": "^4.14.173",
    "@types/node": "^18.19.17",
    "copyfiles": "^2.4.1",
    "homebridge": "^1.6.0 || ^2.0.0",
    "rimraf": "^3.0.2",
    "typescript": "~5.6"
  }
}
